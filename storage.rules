rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperuser() {
      return signedIn() && request.auth.token.email == 'julio.bitaraes.mail@gmail.com';
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid));
    }

    function hasUserDoc() {
      return signedIn() && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid));
    }

    function role() {
      return isSuperuser() ? 'superadmin' : (hasUserDoc() ? userDoc().data.role : null);
    }

    function currentSchoolId() {
      return hasUserDoc() ? userDoc().data.escola_id : null;
    }

    function sameSchool(pathSchoolId) {
      return isSuperuser() || (currentSchoolId() != null && pathSchoolId == currentSchoolId());
    }

    match /matriculas/{schoolId}/{studentSlug}/{folder}/{fileName} {
      allow read, write: if signedIn() && sameSchool(schoolId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}